{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "HuaweiCRM": {
    "HuaweiCRMBaseUri": "http://127.0.0.1:5000"
  },
  "RedisMessages": {
    "ConnectionString": "localhost:6379,abortConnect=false",
    "KeyPrefix": "topup:error:",
    "HashKey": "topup:error:messages"
  }
}
